---
---

<section class="py-16 px-6 bg-card">
  <h2 class="font-display text-3xl md:text-4xl text-center text-foreground mb-2 animate-fade-in">
    Ubicación
  </h2>
  <div class="flex justify-center mb-10">
    <div class="h-[2px] w-20 rounded-full rainbow-border"></div>
  </div>

  <div class="max-w-md mx-auto animate-fade-up">
    <div class="rounded-lg overflow-hidden border border-border shadow-sm mb-4">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3762.661!2d-99.1332!3d19.4326!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTnCsDI1JzU3LjQiTiA5OcKwMDcnNTkuNSJX!5e0!3m2!1ses!2smx!4v1"
        width="100%"
        height="250"
        style="border:0"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Ubicación del evento"
      ></iframe>
    </div>

    <div class="flex items-start gap-3 mb-4">
      <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
      <div>
        <p class="font-elegant text-lg text-foreground font-semibold">Jardín La Rosa de Cristal</p>
        <p class="font-body text-sm text-muted-foreground">Av. Reforma 452, Col. Centro, CDMX</p>
      </div>
    </div>

    <a
      href="https://maps.google.com"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center justify-center gap-2 w-full border border-primary text-primary font-body text-sm tracking-[0.1em] uppercase py-3 rounded-lg hover:bg-primary hover:text-primary-foreground transition-all duration-300"
    >
      <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
      Cómo llegar
    </a>
  </div>
</section>

<style>
  .animate-fade-in { opacity: 0; animation: fadeIn 0.8s ease forwards; }
  .animate-fade-up { opacity: 0; transform: translateY(20px); animation: fadeUp 0.6s ease forwards; }
  @keyframes fadeIn { to { opacity: 1; } }
  @keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }
</style>
